# Required: Zoom Server-to-Server OAuth credentials
ZOOM_ACCOUNT_ID=your_zoom_account_id_here
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here

# Required: Groq API key (free tier available at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Model overrides (uncomment to use non-default models)
# LLM_MODEL=llama-3.3-70b-versatile
# WHISPER_MODEL=whisper-large-v3-turbo

# Note: Groq API key above is used for both transcription and enrichment

# Jira Cloud integration (optional — only needed for 'jira' command)
JIRA_URL=https://example.atlassian.net
JIRA_EMAIL=rexample@email.com
JIRA_API_TOKEN=example_api_token
JIRA_PROJECT_KEY=EXAMPLE

# Zoom webhook integration (optional — only needed for webhook endpoint)
ZOOM_WEBHOOK_SECRET_TOKEN=your_webhook_secret_token_here

# Local/private backend configuration (optional — only needed for --local-backend)
OLLAMA_URL=http://localhost:11434
USE_LOCAL_BACKEND=false

# Speaker diarization (optional — only needed for --diarize)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Slack/Teams notifications (optional — only needed for --notify flag)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/YOUR/WEBHOOK/URL
# Action item follow-up tracker (optional — SQLite DB for tracking action items)
TRACKER_DB=~/.zoom-insights.db
